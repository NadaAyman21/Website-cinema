<div class="forgot-password-card">
  <button class="modal-close" onclick="closeForgot()">✕</button>
  <h2>FORGOT YOUR PASSWORD</h2>
  <form id="forgotForm">
    <label for="forgotEmail">ENTER YOUR EMAIL ADDRESS BELOW:</label>
    <input type="email" id="forgotEmail" name="email" required placeholder="your@email.com">
    <button type="submit" class="reset-btn">RESET PASSWORD</button>

    <p id="forgotError"   style="color:#f43f5e; font-size:13px; margin-top:10px;"></p>
    <p id="forgotSuccess" style="color:#c9a84c; font-size:13px; margin-top:10px;"></p>
  </form>
  <div class="footer-links">
    <a href="#" class="back-link" onclick="closeForgot(); openLogin(); return false;">← Go back to login</a>
  </div>
</div>
  