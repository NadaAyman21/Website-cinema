<div class="login-box">
  <button class="modal-close" onclick="closeLogin()">✕</button>
  <h2>Login to your account</h2>

  <form id="loginForm">

    <div class="field-group">
      <label for="loginEmail">Email</label>
      <input type="email" id="loginEmail" placeholder="Enter your email">
      <span class="error" id="loginEmailError"></span>
    </div>

    <div class="field-group">
      <label for="loginPassword">Password</label>
      <div class="password-box">
        <input type="password" id="loginPassword" placeholder="Enter your password">
        <span onclick="togglePassword()">👁</span>
      </div>
      <span class="error" id="loginPasswordError"></span>
    </div>

    <a href="#" class="forgot-link" onclick="openForgot(); return false;">Forgot Password?</a>

    <button class="btn-login" type="submit">Login</button>

  </form>

  <div class="create-account">
    <a href="#" onclick="closeLogin(); openSignup(); return false;">Create a new account</a>
  </div>

</div>