<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <link rel="stylesheet" href="css/forget.css">
</head>
<body style="background:#111; display:flex; justify-content:center; align-items:center; height:100vh;">

    <!-- Standalone version for direct access -->
    <div class="forgot-password-card">
        <h2>FORGOT YOUR PASSWORD</h2>
        <form id="forgotForm">
            <label for="email">ENTER YOUR EMAIL ADDRESS BELOW:</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com">
            <button type="submit" class="reset-btn">RESET PASSWORD</button>
        </form>
        <div class="footer-links">
            <a href="#" onclick="history.back()" class="back-link">← Go back to login</a>
        </div>
    </div>

    <script src="js/forget.js"></script>
</body>
</html>