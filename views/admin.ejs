<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard — CineX</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/admin.css">
<link rel="stylesheet" href="/css/responsive.css">
</head>

<body>
<div class="navbar">
  <h2>🎬 CineX Admin</h2>
  <button class="logout" onclick="logout()">
    <i class="fa-solid fa-arrow-right-from-bracket" style="margin-right:6px; color:inherit;"></i>Logout
  </button>
</div>

<div class="container">
  <form id="movieForm" novalidate>
    <h3><i class="fa-solid fa-film"></i> Add / Edit Movie</h3>

    <div class="form-grid">
      <input type="text" id="title"   placeholder="Movie Title"              >
      <input type="text" id="genre"   placeholder="Genre"                    >
      <input type="text" id="time"    placeholder="Run Time (e.g. 2h 30m)"   >
      <input type="text" id="age"     placeholder="Age Rating (e.g. +12)"    >
      <input type="text" id="image"   placeholder="Image URL"      class="full">
      <input type="text" id="trailer" placeholder="YouTube Embed Link"   class="full">
      <input type="text" id="cast"    placeholder="Cast (comma-separated)"       class="full">
      <textarea          id="story"   placeholder="Story / Synopsis"            class="full"></textarea>

      <div class="input-group full" style="grid-column: 1 / -1; margin-top: 10px;">
        <label style="font-size:12px; color:#6b6b80; letter-spacing:0.08em; display:block; margin-bottom:6px;">SHOWTIMES</label>
        
        <div class="showtimes-builder" id="showtimesBuilder" style="margin-bottom:12px; min-height: 20px;"></div>
        
        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
          <select id="showtimeDaySelect" style="border-radius:9px; padding:10px; background:#1e1e2f; color:#fff; border:1px solid #333; height:42px; font-size:13px; cursor:pointer;">
            <option value="SUN">SUN</option>
            <option value="MON">MON</option>
            <option value="TUE">TUE</option>
            <option value="WED">WED</option>
            <option value="THU">THU</option>
            <option value="FRI">FRI</option>
            <option value="SAT">SAT</option>
          </select>

          <select id="showtimeExpSelect" style="border-radius:9px; padding:10px; background:#1e1e2f; color:#fff; border:1px solid #333; height:42px; font-size:13px; cursor:pointer;">
            <option value="STANDARD&DELUXE">STANDARD & DELUXE</option>
            <option value="PREMIERE">PREMIERE</option>
          </select>

          <input type="text" id="showtimeInput" placeholder="e.g. 02:00 PM" style="max-width:130px; height:42px; padding:0 12px; margin:0; font-size:13px;">
          
          <button type="button" onclick="addShowtime()"
            style="background:var(--accent, #6c5ce7); color:#fff; border:none; border-radius:9px; padding:0 20px; cursor:pointer; font-weight:600; height:42px; display:inline-flex; align-items:center; justify-content:center;">
            + Add
          </button>
        </div>
      </div>
    </div>

    <div class="form-footer" style="margin-top: 20px;">
      <button type="submit">
        <i class="fa-solid fa-floppy-disk" style="color:white;"></i> Save Movie
      </button>
    </div>
  </form>

  <p class="section-heading"><i class="fa-solid fa-layer-group" style="font-size:10px;"></i> All Movies</p>
  <div class="movies" id="moviesList"></div>

</div>

<div id="customAlert" class="custom-modal">
  <div class="modal-content black-theme">
    <h3 id="alertTitle">CineX.com says</h3>
    <p id="alertMessage"></p>
    <button onclick="closeAlert()">OK</button>
  </div>
</div>

<section id="reservations-section" style="margin-top:2.5rem; padding: 0 20px;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
    <h2><i class="fa-solid fa-ticket" style="font-size:0.9rem; margin-right:8px;"></i>Reservations</h2>
    <button onclick="clearAllReservations()" id="clearAllBtn">
      <i class="fa-solid fa-trash-can" style="color:inherit; margin-right:5px;"></i>Clear All
    </button>
  </div>

  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:1.5rem;">
    <div class="admin-stat-card">
      <div class="stat-label">Total Bookings</div>
      <div class="stat-value" id="statTotal">0</div>
    </div>
    <div class="admin-stat-card">
      <div class="stat-label">Seats Booked</div>
      <div class="stat-value" id="statSeats">0</div>
    </div>
    <div class="admin-stat-card">
      <div class="stat-label">Revenue (EGP)</div>
      <div class="stat-value" id="statRevenue">0</div>
    </div>
  </div>

  <input type="text" id="reservationSearch" placeholder="Search by movie or customer…" oninput="renderReservations()">

  <div style="overflow-x:auto; border-radius:14px;">
    <table id="reservationsTable" style="width:100%; border-collapse:collapse; min-width:600px;">
      <thead>
        <tr>
          <th>#</th>
          <th>MOVIE</th>
          <th>CUSTOMER</th>
          <th>DATE / TIME</th>
          <th>SEATS</th>
          <th>TOTAL</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="reservationsBody"></tbody>
    </table>
    <div id="reservationsEmpty" style="display:none; text-align:center; padding:2.5rem; color:#6b6b80; font-size:13.5px;">
      No reservations yet.
    </div>
  </div>
</section>

<script src="/js/admin.js"></script>
</body>
</html>