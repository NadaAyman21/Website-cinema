<section class="premiere">

    <h1 data-i18n="premiereTitle">PREMIERE</h1>

    <div class="gallery">
        <img src="/images/image 1.jpeg" alt="Cinema 1">
        <img src="/images/image 2.jpeg" alt="Cinema 2">
        <img src="/images/image 3.jpeg" alt="Cinema 3">
    </div>

    <p class="description" data-i18n="premiereDesc">
        Our Premiere halls are designed to create an unforgettable experience, where every detail is tailored to your comfort and enjoyment.
        Indulge in the ultimate cinematic luxury with our Premiere cinema halls. Our exclusive seating features chaise lounge chairs that recline,
        offering unmatched relaxation and sophistication. Sink into plush cushioning and enjoy the show in a way that elevates traditional movie-watching.
    </p>

    <div class="conditions">
        <h2 data-i18n="conditionsTitle">Conditions of Entry</h2>
        <ul>
            <li data-i18n="condition1">Please note that children under the age of 12 are not permitted to attend Premiere Experience shows.</li>
            <li data-i18n="condition2">Please note that children under 3 years of age are not permitted at any screenings.</li>
            <li data-i18n="condition3">Outside food and beverages are not permitted inside cinema halls.</li>
            <li data-i18n="condition4">Valid ID showing proof of age is required for admission for certain movie classifications.</li>
        </ul>
    </div>

</section>

<section class="embed-reviews-section glass-panel">
    <h2 data-i18n="premiereReviews">Premiere Reviews</h2>
    <p data-i18n="premiereReviewsDesc">Read what our guests say about their luxurious Premiere experience at CineX!</p>

    <div class="reviews-embed-grid">
        <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
                <article class="review-card">
                    <div class="review-card-header">
                        <div>
                            <h3 class="review-movie-name"><%= review.item %></h3>
                            <div class="review-author">by <%= review.userName %></div>
                        </div>
                        <div class="review-rating-stars">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= review.rating) { %>
                                    <i class="fa-solid fa-star"></i>
                                <% } else { %>
                                    <i class="fa-regular fa-star" style="opacity: 0.3;"></i>
                                <% } %>
                            <% } %>
                        </div>
                    </div>
                    <p class="review-comment">"<%= review.comment %>"</p>
                </article>
            <% }) %>
        <% } else { %>
            <div class="no-reviews" style="grid-column: 1 / -1;">
                <i class="fa-regular fa-comments" style="font-size: 2.5rem; display: block; margin-bottom: 12px; opacity: 0.5;"></i>
                <span data-i18n="noReviews">No Premiere reviews yet. Be the first to share your experience on the</span>
                <a href="/reviews" style="color: var(--accent); text-decoration: underline;" data-i18n="reviewsPage">Reviews page</a>!
            </div>
        <% } %>
    </div>
</section>