<!DOCTYPE html>
<html lang="en">
<head>
    <title>My Profile - CineX</title>
   <link rel="stylesheet" href="/css/nav.css">
<link rel="stylesheet" href="/css/profile.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/sign%20up%20page.css">
<link rel="stylesheet" href="/css/forget.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/nav') %>

    <div class="profile-page">

        <!-- Hero Banner -->
        <div class="profile-banner">
            <div class="banner-overlay"></div>
            <div class="banner-content">
                <div class="avatar-ring">
                    <div class="avatar-initials">
                        <%= user.firstName ? user.firstName[0].toUpperCase() : 'U' %><%= user.lastName ? user.lastName[0].toUpperCase() : '' %>
                    </div>
                </div>
                <div class="banner-text">
                    <h1><%= user.firstName %> <%= user.lastName %></h1>
                    <p class="member-since"><i class="fa fa-film"></i> CineX Member</p>
                </div>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar">
            <div class="stat-item">
                <span class="stat-number" id="moviesCount">0</span>
                <span class="stat-label">Movies Watched</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number" id="ticketsCount">0</span>
                <span class="stat-label">Tickets Booked</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number" id="upcomingCount">0</span>
                <span class="stat-label">Upcoming</span>
            </div>
        </div>

        <!-- Tabs -->
        <div class="profile-tabs">
            <button class="tab-btn active" onclick="switchTab('info')">
                <i class="fa fa-user"></i> Personal Info
            </button>
            <button class="tab-btn" onclick="switchTab('tickets')">
                <i class="fa fa-ticket"></i> My Tickets
            </button>
            <button class="tab-btn" onclick="switchTab('history')">
                <i class="fa fa-clock"></i> History
            </button>
            <button class="tab-btn" onclick="switchTab('settings')">
                <i class="fa fa-gear"></i> Settings
            </button>
        </div>

        <!-- Body -->
        <div class="profile-body">

            <!-- Info Tab -->
            <div class="tab-content active" id="tab-info">
                <div class="info-grid">
                    <div class="info-card">
                       <div class="info-card-header">
                            <i class="fa fa-user"></i> Personal Info
                            <button class="edit-btn" onclick="openEditModal()">
                                <i class="fa fa-pen"></i> Edit
                            </button>
                        </div>
                        <div class="info-rows">
                            <div class="info-row">
                                <span class="info-label">First Name</span>
                                <span class="info-value"><%= user.firstName %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Last Name</span>
                                <span class="info-value"><%= user.lastName %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Gender</span>
                                <span class="info-value"><%= user.gender %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Date of Birth</span>
                                <span class="info-value"><%= user.dob %></span>
                            </div>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-header">
                            <i class="fa fa-envelope"></i> Contact Info
                        </div>
                        <div class="info-rows">
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value"><%= user.email %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value"><%= user.phone %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tickets Tab -->
            <div class="tab-content" id="tab-tickets">
                <div class="empty-state">
                    <i class="fa fa-ticket"></i>
                    <p>No upcoming tickets</p>
                    <a href="/cinemaM" class="cta-btn">Browse Movies</a>
                </div>
            </div>

            <!-- History Tab -->
            <div class="tab-content" id="tab-history">
                <div class="empty-state">
                    <i class="fa fa-clock"></i>
                    <p>No watch history yet</p>
                    <a href="/cinemaM" class="cta-btn">Browse Movies</a>
                </div>
            </div>

            <!-- Settings Tab -->
            <div class="tab-content" id="tab-settings">
                <div class="settings-list">
                    <div class="settings-item">
                        <div>
                            <div class="settings-title">Email Notifications</div>
                            <div class="settings-sub">Receive booking confirmations</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox" checked>
                            <span class="slider"></span>
                        </label>
                    </div>
                    <div class="settings-item danger-zone">
                        <div>
                            <div class="settings-title">Delete Account</div>
                            <div class="settings-sub">Permanently remove your account</div>
                        </div>
                        <button class="danger-btn">Delete</button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Edit Info Modal -->
<div class="modal-overlay" id="editModal">
    <div class="modal">
        <div class="modal-header">
            <h2>Edit Info</h2>
            <button onclick="closeEditModal()"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-form">
            <div class="form-row">
                <label>First Name</label>
                <input type="text" id="editFirstName" value="<%= user.firstName %>">
            </div>
            <div class="form-row">
                <label>Last Name</label>
                <input type="text" id="editLastName" value="<%= user.lastName %>">
            </div>
            <div class="form-row">
                <label>Phone</label>
                <input type="text" id="editPhone" value="<%= user.phone %>">
            </div>
            <div class="form-row">
                <label>Date of Birth</label>
                <input type="date" id="editDob" value="<%= user.dob %>">
            </div>
            <button class="submit-btn" onclick="saveEdit()">Save Changes</button>
        </div>
    </div>
</div>

    <script src="/js/nav.js"></script>
    <script>
        function switchTab(name) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            event.currentTarget.classList.add('active');
        }
    </script>

</body>
</html>