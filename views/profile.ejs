<!DOCTYPE html>
<html lang="en">
<head>
    <title>My Profile - CineX</title>
   <link rel="stylesheet" href="/css/nav.css">
<link rel="stylesheet" href="/css/profile.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/sign up page.css">
<link rel="stylesheet" href="/css/forget.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/nav') %>

    <div class="profile-page">

       
        <div class="profile-banner">
            <div class="banner-overlay"></div>
            <div class="banner-content">
                <div class="avatar-ring">
                    <div class="avatar-initials">
                        <%= user.firstName ? user.firstName[0].toUpperCase() : 'U' %><%= user.lastName ? user.lastName[0].toUpperCase() : '' %>
                    </div>
                </div>
                <div class="banner-text">
                    <h1><%= user.firstName %> <%= user.lastName %></h1>
                    <p class="member-since"><i class="fa fa-film"></i> CineX Member</p>
                </div>
            </div>
        </div>

        <div class="stats-bar">
            <div class="stat-item">
                <span class="stat-number" id="moviesCount">0</span>
                <span class="stat-label">Movies Watched</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number" id="ticketsCount">0</span>
                <span class="stat-label">Tickets Booked</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number" id="upcomingCount">0</span>
                <span class="stat-label">Upcoming</span>
            </div>
        </div>

      
        <div class="profile-tabs">
            <button class="tab-btn active" onclick="switchTab('info')">
                <i class="fa fa-user"></i> Personal Info
            </button>
            <button class="tab-btn" onclick="switchTab('tickets')">
                <i class="fa fa-ticket"></i> My Tickets
            </button>
            <button class="tab-btn" onclick="switchTab('history')">
                <i class="fa fa-clock"></i> History
            </button>
            <button class="tab-btn" onclick="switchTab('settings')">
                <i class="fa fa-gear"></i> Settings
            </button>
        </div>
        <div class="profile-body">

            <div class="tab-content active" id="tab-info">
                <div class="info-grid">
                    <div class="info-card">
                       <div class="info-card-header">
                            <i class="fa fa-user"></i> Personal Info
                            <button class="edit-btn" onclick="openEditModal()">
                                <i class="fa fa-pen"></i> Edit
                            </button>
                        </div>
                        <div class="info-rows">
                            <div class="info-row">
                                <span class="info-label">First Name</span>
                                <span class="info-value"><%= user.firstName %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Last Name</span>
                                <span class="info-value"><%= user.lastName %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Gender</span>
                                <span class="info-value"><%= user.gender %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Date of Birth</span>
                                <span class="info-value"><%= user.dob %></span>
                            </div>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-header">
                            <i class="fa fa-envelope"></i> Contact Info
                        </div>
                        <div class="info-rows">
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value"><%= user.email %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value"><%= user.phone %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

          <div class="tab-content" id="tab-tickets">
  <% if (reservations.length === 0) { %>
    <div class="empty-state">
      <i class="fa fa-ticket"></i>
      <p>No upcoming tickets</p>
      <a href="/cinemaM" class="cta-btn">Browse Movies</a>
    </div>
  <% } else { %>
    <div class="tickets-grid">
      <% reservations.forEach(r => { %>
        <div class="ticket-card">
          <div class="ticket-card-left">
            <div class="tc-movie"><%= r.movie %></div>
            <div class="tc-hall"><%= r.hall %> Hall</div>
            <div class="tc-meta">
              <span><i class="fa fa-calendar"></i> <%= r.date %></span>
              <span><i class="fa fa-clock"></i> <%= r.showtime %></span>
            </div>
            <div class="tc-seats">
              <% r.seats.forEach(s => { %>
                <span class="tc-seat-tag"><%= s %></span>
              <% }) %>
            </div>
          </div>
          <div class="ticket-card-right">
            <div class="tc-price"><%= r.totalPrice %> EGP</div>
            <div class="tc-order"><%= r.orderNumber %></div>
            <a href="/ticket/<%= r._id %>" class="tc-view-btn">View Ticket</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- History Tab -->
<div class="tab-content" id="tab-history">
  <% if (reservations.length === 0) { %>
    <div class="empty-state">
      <i class="fa fa-clock"></i>
      <p>No watch history yet</p>
      <a href="/cinemaM" class="cta-btn">Browse Movies</a>
    </div>
  <% } else { %>
    <div class="history-list">
      <% reservations.forEach(r => { %>
        <div class="history-item">
          <div class="history-icon"><i class="fa fa-film"></i></div>
          <div class="history-info">
            <div class="history-movie"><%= r.movie %></div>
            <div class="history-detail"><%= r.hall %> Hall · <%= r.date %> · <%= r.showtime %></div>
            <div class="history-seats">Seats: <%= r.seats.join(', ') %></div>
          </div>
          <div class="history-price"><%= r.totalPrice %> EGP</div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

            <div class="tab-content" id="tab-settings">
                <div class="settings-list">
                    <div class="settings-item">
                        <div>
                            <div class="settings-title">Email Notifications</div>
                            <div class="settings-sub">Receive booking confirmations</div>
                        </div>
                        <label class="toggle">
                            <input type="checkbox" checked>
                        </label>
                    </div>
                    <div class="settings-item">
                        <div>
                            <div class="settings-title">Change Password</div>
                            <div class="settings-sub">Update your current password</div>
                        </div>
                        <button class="change-pass-btn" onclick="openPasswordModal()">Change</button>
                    </div>

                    <div class="settings-item danger-zone">
                        <div>
                            <div class="settings-title">Delete Account</div>
                            <div class="settings-sub">Permanently remove your account</div>
                        </div>
                        <button class="danger-btn" onclick="openDeleteModal()">Delete</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <div class="modal-header">
            <h2 style="color: #e83b3b;"><i class="fa fa-exclamation-triangle"></i> Delete Account</h2>
            <button onclick="closeDeleteModal()"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-form">
            <p style="color: #fff; margin-bottom: 15px; font-size: 14px;">
                Warning: This action is permanent. All associated ticket records and information will be completely removed.
            </p>
            <div class="form-row">
                <label>Enter your account password to proceed</label>
                <input type="password" id="deletePasswordInput" placeholder="Password Verification Check">
            </div>
            <p id="deletePasswordError" style="color:#e83b3b; font-size:13px; display:none; margin-bottom: 10px;"></p>
            <button class="submit-btn" style="background-color: #e83b3b;" onclick="confirmDeleteAccount()">Delete My Account Permanently</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="passwordModal">
    <div class="modal">
        <div class="modal-header">
            <h2>Change Password</h2>
            <button onclick="closePasswordModal()"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-form">
            <div class="form-row">
                <label>Current Password</label>
                <input type="password" id="currentPassword" placeholder="Enter current password">
            </div>
            <div class="form-row">
                <label>New Password</label>
                <input type="password" id="newPassword" placeholder="Enter new password">
            </div>
            <div class="form-row">
                <label>Confirm New Password</label>
                <input type="password" id="confirmNewPassword" placeholder="Confirm new password">
            </div>
            <p id="passwordError" style="color:#e83b3b; font-size:13px; display:none;"></p>
            <button class="submit-btn" onclick="savePassword()">Save Password</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="editModal">
    <div class="modal">
        <div class="modal-header">
            <h2>Edit Info</h2>
            <button onclick="closeEditModal()"><i class="fa fa-times"></i></button>
        </div>
        <div class="modal-form">
            <div class="form-row">
                <label>First Name</label>
                <input type="text" id="editFirstName" value="<%= user.firstName %>">
            </div>
            <div class="form-row">
                <label>Last Name</label>
                <input type="text" id="editLastName" value="<%= user.lastName %>">
            </div>
            <div class="form-row">
                <label>Phone</label>
                <input type="text" id="editPhone" value="<%= user.phone %>">
            </div>
            <div class="form-row">
                <label>Date of Birth</label>
                <input type="date" id="editDob" value="<%= user.dob %>">
            </div>
            <button class="submit-btn" onclick="saveEdit()">Save Changes</button>
        </div>
    </div>
</div>

    <script src="/js/nav.js"></script>
    <script src="/js/profile.js"></script>
    <script src="/js/theme.js"></script>

<script>
        document.getElementById('ticketsCount').textContent = '<%= reservations.length %>';
        document.getElementById('moviesCount').textContent  = '<%= new Set(reservations.map(r => r.movie)).size %>';
        document.getElementById('upcomingCount').textContent = '<%= reservations.length %>';
    </script>
</body>
</html>