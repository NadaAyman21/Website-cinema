
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CineBook - Home</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/cinema.css">
<link rel="stylesheet" href="/css/nav.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/forget.css">
<link rel="stylesheet" href="/css/sign up page.css">
<link rel="stylesheet" href="/css/footer.css">

<link rel="stylesheet" href="/css/responsive.css">
 

</head>

<body>
<%- include('partials/nav') %>
<br>
<br>
<br>
<!-- HERO SLIDER -->

<section class="hero">

<div class="slider">

<div class="slide active">
<img src="/images/homepage.jpg">
<div class="caption">
<h2 data-i18n="heroTitle">Experience Movies Like Never Before</h2>
<p  data-i18n="heroSub">Book tickets instantly and enjoy the latest block blusters</p>
</div>
</div>

<div class="slide">
<img src="/images/inter1.jpg">
<div class="caption">
<h2>Interstellar</h2>
<p>Sci-Fi</p>
</div>
</div>

<div class="slide">
<img src="/images/f1land.jpg">
<div class="caption">
<h2>F1</h2>
<p>Sport/action</p>
</div>
</div>

<div class="slide">
<img src="/images/ioland.jpg">
<div class="caption">
<h2>Inside Out</h2>
<p>Family/comedy</p>
</div>
</div>

<div class="slide">
<img src="/images/weladland.jpg">
<div class="caption">
<h2>ولاد رزق</h2>
<p>Action</p>
</div>
</div>

<div class="slide">
<img src="/images/landscape2.webp">
<div class="caption">
<h2>La La Land</h2>
<p>Musical/Romantic</p>
</div>
</div>

<div class="slide">
<img src="/images/conjuring.webp">
<div class="caption">
<h2>The Conjuring</h2>
<p>Horror</p>
</div>
</div>


</div>
<div class="dots" id="dots"></div>

</section>


<!-- MOVIES -->

<section class="movies" id="now-showing" >

<h2 data-i18n="nowShowing">Now Showing</h2>

<div class="movie-container" id="moviesList"></div>


</section>
<section class="experiences">
    <h2 data-i18n="experiences">EXPERIENCES</h2>
<p data-i18n="experiencesDesc">AT CineX, WE BELIEVE IN CREATING UNFORGETTABLE MOVIE EXPERIENCES</p>

    <div class="cards">

        <div class="card premiere">
            <a href="/premier" class="card premiere">
            <div class="overlay">
                <h3 data-i18n="premiere">PREMIERE</h3>
            
            </div></a>
        </div>

        <div class="card deluxe">
            <a href="/stanard" class="card deluxe">
            <div class="overlay">
                <h3 data-i18n="deluxe">DELUXE</h3>
        </div>  </a>
        </div>

        <div class="card standard">
             <a href="/stanard" class="card stanard">
            <div class="overlay">
                <h3 data-i18n="standardCard">STANDARD</h3>
            </div></a>
        </div>

    </div>
</section>


<script src="/js/nav.js"></script>
<script src="/js/login.js"></script>
<script src="/js/sign up page.js"></script>
<script src="/js/forget.js"></script>
<script src="/js/cinema.js"></script>
<script src="/js/theme.js"></script>
<%- include('partials/footer') %>
</body>
</html>

