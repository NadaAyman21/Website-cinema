<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CineX — Select Seats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/css/normalSeat.css">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;900&family=Raleway:wght@200;300;400;600&display=swap" rel="stylesheet">
</head>
<body>

  <div id="cursor"></div>

  <div id="grain"></div>

  <div id="switch-overlay"></div>

    <div id="loader">
    <div class="loader-logo">CINEX</div>
    <div class="loader-sub">Hall Selection</div>
    <div class="loader-bar"><div class="loader-fill"></div></div>
    <div class="loader-text">Preparing your experience...</div>
  </div>

    <canvas id="cinema-canvas"></canvas>

  <div id="hall-tabs">
    <button class="hall-tab std active" onclick="switchHall('standard')">Standard</button>
    <button class="hall-tab dlx" onclick="switchHall('deluxe')">Deluxe</button>
  </div>

   <div id="topbar">
    <div class="logo">CINEX <span id="tier-badge" class="tier-badge std">STD</span></div>
    <div id="view-toggle">
      <button class="view-btn active" onclick="setView('audience')">Audience</button>
      <button class="view-btn" onclick="setView('top')">Overview</button>
      <button class="view-btn" onclick="setView('fly')">Fly Around</button>
    </div>
    <div id="max-label">MAX 8 SEATS</div>
  </div>

    <div id="tooltip">
    <div class="tip-seat std" id="tip-seat">A1</div>
    <div class="tip-price" id="tip-price">EGP 120</div>
    <div class="tip-status" id="tip-status">Available</div>
  </div>

    <div id="instructions">
    <div class="drag-hint">
      <span>←</span>
      <p>Drag to look around · Scroll to zoom · Click a seat to select</p>
      <span>→</span>
    </div>
  </div>

   <div id="seat-panel">
    <div class="panel-inner">

      <!-- Legend -->
      <div class="legend" id="legend">
        <div class="legend-item">
          <div class="legend-dot ld-seat-std" id="ld-seat"></div>
          <span id="ld-seat-label">Standard</span>
        </div>
        <div class="legend-item">
          <div class="legend-dot ld-selected-std" id="ld-selected"></div>
          Selected
        </div>
        <div class="legend-item">
          <div class="legend-dot ld-hold"></div>
          On Hold
        </div>
        <div class="legend-item">
          <div class="legend-dot ld-taken"></div>
          Taken
        </div>
      </div>

            <div class="selection-info">
        <div class="selection-count std" id="sel-count">0</div>
        <div class="selection-label">seats selected</div>
        <div class="seat-tags" id="seat-tags"></div>
      </div

       <button id="book-btn" class="std" disabled onclick="openConfirm()">
        Reserve Seats →
      </button>

    </div>
  </div>

   <div id="confirm-modal">
    <div class="modal-box">
      <div class="modal-corner tl" id="mc-tl"></div>
      <div class="modal-corner tr" id="mc-tr"></div>
      <div class="modal-corner bl" id="mc-bl"></div>
      <div class="modal-corner br" id="mc-br"></div>
      <div class="modal-icon">🎬</div>
      <div class="modal-title" id="modal-title">Confirm Reservation</div>
      <div class="modal-sub" id="modal-sub">Standard Hall · Tonight 9:00 PM</div>
      <div class="modal-seats" id="modal-seats"></div>
      <div class="modal-total">Total</div>
      <div class="modal-price" id="modal-price">EGP 0</div>
      <div class="modal-btns">
        <button class="btn-cancel" onclick="closeConfirm()">Cancel</button>
        <button class="btn-confirm std" id="btn-confirm" onclick="confirmBook()">Confirm &amp; Pay</button>
      </div>
    </div>
  </div>
