<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CineX — Select Seats</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="/css/normalSeat.css">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;900&family=Raleway:wght@200;300;400;600&display=swap" rel="stylesheet">
</head>
<body>

  <div id="cursor"></div>

  <div id="grain"></div>

  <div id="switch-overlay"></div>

    <div id="loader">
    <div class="loader-logo">CINEX</div>
    <div class="loader-sub">Hall Selection</div>
    <div class="loader-bar"><div class="loader-fill"></div></div>
    <div class="loader-text">Preparing your experience...</div>
  </div>

    <canvas id="cinema-canvas"></canvas>

  <div id="hall-tabs">
    <button class="hall-tab std active" onclick="switchHall('standard')">Standard</button>
    <button class="hall-tab dlx" onclick="switchHall('deluxe')">Deluxe</button>
  </div>

   <div id="topbar">
    <div class="logo">CINEX <span id="tier-badge" class="tier-badge std">STD</span></div>
    <div id="view-toggle">
      <button class="view-btn active" onclick="setView('audience')">Audience</button>
      <button class="view-btn" onclick="setView('top')">Overview</button>
      <button class="view-btn" onclick="setView('fly')">Fly Around</button>
    </div>
    <div id="max-label">MAX 8 SEATS</div>
  </div>