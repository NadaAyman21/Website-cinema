<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cinema Menu</title>
<link rel="stylesheet" href="/css/sign up page.css">
    <!-- Google Font -->
     <link rel="stylesheet" href="/css/forget.css">
     <link rel="stylesheet" href="/css/login.css">
   <link rel="stylesheet" href="/css/nav.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="/css/responsive.css">
    <link rel="stylesheet" href="/css/food.css">
      <link rel="stylesheet" href="/css/reviews.css">
</head>

<body>
<%- include('partials/nav') %>
          
<br><br>
<header>
    <h1>Menu</h1>
</header>

<main class="menu-container">

    <!-- 🍿 POPCORN -->
    <section class="menu-category">
        <div class="category-header">
            <img src="images/popcorn.jpeg" alt="">
            <div>
                <h2>Popcorn</h2>
                <p class="subtitle">(Salt, Caramel, Cheese, Cheetos Original)</p>
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Small Popcorn</span><span>120 LE</span></div>
            <div class="item"><span>Medium Popcorn</span><span>135 LE</span></div>
            <div class="item"><span>Large Popcorn</span><span>160 LE</span></div>
        </div>
    </section>

    <!-- ☕ HOT DRINKS -->
    <section class="menu-category">
        <div class="category-header">
            <img src="images/hot drink.jpeg" alt="">
            <div>
                <h2>Hot Drinks</h2>
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Espresso</span><span>65 LE</span></div>
            <div class="item"><span>Double Espresso</span><span>80 LE</span></div>
            <div class="item"><span>Espresso Macchiato</span><span>85 LE</span></div>
            <div class="item"><span>Cappuccino</span><span>120 LE</span></div>
            <div class="item"><span>Latte</span><span>125 LE</span></div>
            <div class="item"><span>Flat White</span><span>90 LE</span></div>
            <div class="item"><span>Hot Chocolate</span><span>110 LE</span></div>
            <div class="item"><span>French Coffee</span><span>70 LE</span></div>
            <div class="item"><span>Turkish Coffee</span><span>50 LE</span></div>
            <div class="item"><span>Double Turkish Coffee</span><span>70 LE</span></div>
            <div class="item"><span>Anise</span><span>30 LE</span></div>
            <div class="item"><span>Tea</span><span>30 LE</span></div>
            <div class="item"><span>Tea with Milk</span><span>60 LE</span></div>
        </div>

        <div class="add-ons">
            <p><strong>Add-ons:</strong> Espresso Shot: 40 LE | Milk: 25 LE | Syrup: 35 LE | Sauce: 40 LE</p>
        </div>
    </section>

    <!-- 🧊 COLD DRINKS -->
    <section class="menu-category">
        <div class="category-header">
             <img src="images/cold.jpeg" alt="">
            <div>
                <h2>Cold Drinks</h2>
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Mineral Water</span><span>25 LE</span></div>
            <div class="item"><span>Sparkling Water</span><span>50 LE</span></div>
            <div class="item"><span>Soft Drinks</span><span>50 LE</span></div>
            <div class="item"><span>Red Bull</span><span>80 LE</span></div>
            <div class="item"><span>Juice</span><span>25 LE</span></div>
        </div>
    </section>

    <!-- 🧃 SLUSHIES -->
    <section class="menu-category">
        <div class="category-header">
            <img src="images/slushi.jpeg" alt="">
            <div>
                <h2>Slushies</h2>
               
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Slushie mango</span><span>70 LE</span></div>
             <div class="item"><span>Slushie passion fruit</span><span>70 LE</span></div>
              <div class="item"><span>Slushie redbull</span><span>70 LE</span></div>
               <div class="item"><span>Slushie mix berries</span><span>70 LE</span></div>
            <div class="item"><span>Fresh Juice Slushie</span><span>140 LE</span></div>
        </div>
    </section>

    <section class="menu-category">
        <div class="category-header">
            <img src="images/snacks.jpeg" alt="">
            <div>
                <h2>Snacks & Candy</h2>
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Pringles Small</span><span>115 LE</span></div>
            <div class="item"><span>Chipsy Jumbo</span><span>35 LE</span></div>
             <div class="item"><span>natshos w cheese</span><span>150 LE</span></div>
            <div class="item"><span>Cheetos</span><span>26 LE</span></div>
            <div class="item"><span>Cotton Candy</span><span>40 LE</span></div>
            <div class="item"><span>Loackers</span><span>75 LE</span></div>
        </div>
    </section>

    <!-- 🍫 CHOCOLATES -->
    <section class="menu-category">
        <div class="category-header">
           <img src="images/chocolate.jpeg" alt=""> 
            <div>
                <h2>Chocolates</h2>
            </div>
        </div>

        <div class="menu-grid">
            <div class="item"><span>Kinder</span><span>90 LE</span></div>
            <div class="item"><span>Kinder Bueno</span><span>90 LE</span></div>
            <div class="item"><span>M&M's Small</span><span>80 LE</span></div>
            <div class="item"><span>Maltesers Small</span><span>80 LE</span></div>
            <div class="item"><span>Galaxy</span><span>65 LE</span></div>
            <div class="item"><span>KitKat</span><span>85 LE</span></div>
            <div class="item"><span>Cadbury</span><span>55 LE</span></div>
            <div class="item"><span>Cadbury Bubbly</span><span>40 LE</span></div>
            <div class="item"><span>Twix</span><span>85 LE</span></div>
            <div class="item"><span>Ferrero Rocher</span><span>130 LE</span></div>
            <div class="item"><span>Snickers</span><span>65 LE</span></div>
            <div class="item"><span>Bounty</span><span>75 LE</span></div>
            <div class="item"><span>Flutes</span><span>40 LE</span></div>
            <div class="item"><span>Moro</span><span>35 LE</span></div>
        </div>
    </section>

</main>

<section class="embed-reviews-section glass-panel">
        <h2>Customer Reviews</h2>
        <p>See what our guests are saying about the food and drinks at CineX!</p>

        <div class="reviews-embed-grid">
            <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
                <% reviews.forEach(review => { %>
                    <article class="review-card">
                        <div class="review-card-header">
                            <div>
                                <h3 class="review-movie-name"><%= review.item %></h3>
                                <div class="review-author">by <%= review.userName %></div>
                            </div>
                            <div class="review-rating-stars">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <% if(i <= review.rating) { %>
                                        <i class="fa-solid fa-star"></i>
                                    <% } else { %>
                                        <i class="fa-regular fa-star" style="opacity: 0.3;"></i>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>
                        <p class="review-comment">“<%= review.comment %>”</p>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="no-reviews" style="grid-column: 1 / -1;">
                    <i class="fa-regular fa-comments" style="font-size: 2.5rem; display: block; margin-bottom: 12px; opacity: 0.5;"></i>
                    No food & drinks reviews yet. Be the first to add a review on the <a href="/reviews" style="color: var(--accent); text-decoration: underline;">Reviews page</a>!
                </div>
            <% } %>
        </div>
    </section>
<script src="/js/nav.js"></script>
<script src="/js/login.js"></script>
<script src="/js/sign up page.js"></script>
<script src="/js/forget.js"></script>
 <script src="/js/theme.js"></script>

</body>
</html>