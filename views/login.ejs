<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cinema Seat Reservation - Login</title>
<link rel="stylesheet" href="css/login.css">
<link rel="stylesheet" href="css/responsive.css">
</head>

<body>
  <div class="login-box" style="margin: auto; margin-top: 80px;">
    <h2>Login to your account</h2>
    <form id="loginForm">
      <label>Email</label>
      <input type="email" id="email" placeholder="Enter your email">
      <span id="emailError" class="error"></span>

      <label>Password</label>
      <div class="password-box">
        <input type="password" id="password" placeholder="Enter your password">
        <span onclick="togglePassword()">👁</span>
      </div>
      <span id="passwordError" class="error"></span>
      <p id="error" class="error"></p>

      <div class="options">
      <a href="#" class="forgot-link" onclick="openForgot(); return false;">Forgot Password?</a>
      </div><br>

      <button type="submit">Login</button>

      <p class="create-account">
        <a href="sign up page.html">Create a new account</a>
      </p>
    </form>
  </div>
  <script src="js/login.js"></script>
</body>
</html>