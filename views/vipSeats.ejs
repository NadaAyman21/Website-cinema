<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CineX — VIP Immersive Seat Selection</title>
  <link rel="stylesheet" href="/css/vipS.css">
</head>
<body>

<div id="cursor"></div>
<div id="grain"></div>

<div id="loader">
  <div class="loader-logo">CINEX</div>
  <div class="loader-sub">VIP Experience</div>
  <div class="loader-bar"><div class="loader-fill"></div></div>
  <div class="loader-text">Preparing your private screening...</div>
</div>

<canvas id="cinema-canvas"></canvas>


<div id="hud">
  <div id="topbar">
    <div class="logo">CINEX <span>VIP</span></div>
    <div id="view-toggle">
      <button class="view-btn active" onclick="setView('audience', event)">Audience View</button>
      <button class="view-btn" onclick="setView('top', event)">Overview</button>
      <button class="view-btn" onclick="setView('fly', event)">Fly Around</button>
    </div>
    <div style="font-size:0.65rem;letter-spacing:0.2em;color:rgba(201,168,76,0.5);text-transform:uppercase;">
      MAX 6 SEATS
    </div>
  </div>

    <div id="tooltip">
    <div class="tip-seat" id="tip-seat">A1</div>
    <div class="tip-price" id="tip-price">EGP 450</div>
    <div class="tip-status" id="tip-status">Available</div>
  </div>

  <div id="seat-panel">
    <div class="panel-inner">
      <div class="legend">
        <div class="legend-item"><div class="legend-dot ld-vip"></div>VIP</div>
        <div class="legend-item"><div class="legend-dot ld-selected"></div>Selected</div>
        <div class="legend-item"><div class="legend-dot ld-hold"></div>On Hold</div>
        <div class="legend-item"><div class="legend-dot ld-taken"></div>Taken</div>
      </div>
      <div class="selection-info">
        <div class="selection-count" id="sel-count">0</div>
        <div class="selection-label">seats selected</div>
        <div class="seat-tags" id="seat-tags"></div>
      </div>
      <button id="book-btn" disabled onclick="openConfirm()">
        Reserve Seats →
      </button>
    </div>
  </div>

  <div id="instructions">
    <div class="drag-hint">
      <span>←</span>
      <p>Drag to look around · Scroll to zoom · Click a seat to select</p>
      <span>→</span>
    </div>
  </div>
</div>

<div id="confirm-modal">
  <div class="modal-box">
    <div class="modal-corner tl"></div>
    <div class="modal-corner tr"></div>
    <div class="modal-corner bl"></div>
    <div class="modal-corner br"></div>
    <div class="modal-icon">🎬</div>
    <div class="modal-title">Confirm Reservation</div>
    <div class="modal-sub">VIP Screening · Tonight 9:00 PM</div>
    <div class="modal-seats" id="modal-seats"></div>
    <div class="modal-total">Total</div>
    <div class="modal-price" id="modal-price">EGP 0</div>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeConfirm()">Cancel</button>
      <button class="btn-confirm" onclick="confirmBook()">Confirm & Pay</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="/js/vipS.js"></script>
</body>
</html>
