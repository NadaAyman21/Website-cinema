<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineX — VIP Suite</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="/css/vipS.css">
    <link rel="stylesheet" href="/css/responsive.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/normalSeats.css">
  </head>


<body class="vip-page">

<header>
  <div class="logo"> CineX <span style="font-size: 0.6rem; vertical-align: middle; color: #ffb040; border: 1px solid #ffb040; padding: 2px 4px; border-radius: 4px; margin-left: 5px;">VIP</span></div>
  <div class="movie-meta">
    <h2 id="movieTitleDisplay"></h2>
    <div class="movie-sub" id="movieSub"></div>
  </div>
  <div class="movie-sub" id="movieSub">
  <button class="btn-3d-view" id="btn3dToggle" onclick="toggle3dView()">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
      <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
    </svg>
    3D VIEW
  </button>
</div>
</header>

<div class="limit-warning" id="limitWarning">Maximum 6 seats per booking</div>

<main class="stage">

  <div class="stage-meta">
    <div>Selected: <span id="metaCount">0</span></div>
    <div>Max: <span>6</span> seats</div>
  </div>

  <div class="screen-wrap">
    <div class="screen"></div>
    <div class="screen-label">VIP SCREEN</div>
  </div>

  <div class="theater">
    <div class="rows-container" id="seatsContainer">
      </div>
  </div>

  <div class="legend">
    <div class="legend-item"><div class="legend-seat leg-vip"></div> VIP</div>
    <div class="legend-item"><div class="legend-seat leg-sel-vip"></div> Selected</div>
    <div class="legend-item"><div class="legend-seat leg-hold"></div> On Hold</div>
    <div class="legend-item"><div class="legend-seat leg-occ"></div> Taken</div>
  </div>

</main>

<div class="checkout-bar" id="checkoutBar">
  <div class="checkout-info">
    <div class="checkout-seats" id="checkoutSeats">0 seats selected</div>
    <div class="checkout-price" id="checkoutPrice">EGP 0</div>
  </div>
  <div class="checkout-right">
    <div class="selected-chips" id="selectedChips"></div>
    <button class="btn-checkout" id="btnCheckout" onclick="checkout()">
      Confirm &amp; Pay →
    </button>
  </div>
</div>
<div id="customAlert" class="custom-modal">
    <div class="modal-content black-theme">
        <h3 id="alertTitle">CineX.com says</h3>
        <p id="alertMessage"></p>
        <button onclick="closeAlert()">OK</button>
    </div>
</div>
 
<script src="/js/vipS.js"></script>
<!-- Close button -->
<button class="btn-close-3d" id="btnClose3d" onclick="toggle3dView()">✕ &nbsp;Close 3D</button>

<!-- Custom cursors for 3D mode -->
<div id="cursor3d"></div>
<div id="cursor3d-dot"></div>

<!-- ════ 3D OVERLAY ════ -->
<div id="view3d-overlay">
  <div id="scene3d">
    <div id="cinema-world">

      <div id="ceiling3d">
        <div class="ceiling-lights">
          <div class="ceil-light"></div><div class="ceil-light"></div>
          <div class="ceil-light"></div><div class="ceil-light"></div>
          <div class="ceil-light"></div><div class="ceil-light"></div>
          <div class="ceil-light"></div>
        </div>
      </div>

      <div class="side-drape3d left"><div class="drape-trim3d"></div></div>
      <div class="side-drape3d right"><div class="drape-trim3d"></div></div>

      <div id="wall-left3d">
        <div class="sconce sconce-left sconce-t1"></div>
        <div class="sconce sconce-left sconce-t2"></div>
        <div class="sconce sconce-left sconce-t3"></div>
      </div>
      <div id="wall-right3d">
        <div class="sconce sconce-right sconce-t1"></div>
        <div class="sconce sconce-right sconce-t2"></div>
        <div class="sconce sconce-right sconce-t3"></div>
      </div>

      <div id="screen-arch3d">
        <div class="arch-border3d">
          <div class="corner-ornament3d co-tl3d"></div>
          <div class="corner-ornament3d co-tr3d"></div>
          <div class="corner-ornament3d co-bl3d"></div>
          <div class="corner-ornament3d co-br3d"></div>
        </div>
        <div id="screen3d">
          <div id="screen-content3d">
            <div class="movie-scene3d">
              <div class="stars-layer3d" id="stars3d"></div>
              <div class="moon3d"></div>
              <div class="city-bg3d" id="cityscape3d"></div>
              <div class="water3d">
                <div class="water-reflection3d"></div>
                <div class="water-line3d" style="top:20%;left:10%;width:30%;animation-delay:0s"></div>
                <div class="water-line3d" style="top:45%;left:40%;width:45%;animation-delay:1.5s"></div>
                <div class="water-line3d" style="top:70%;left:5%;width:20%;animation-delay:3s"></div>
              </div>
              <div class="movie-title-card3d">
                <div class="title-line3d"></div>
                <div class="movie-main-title3d" id="screenMovieTitle">NOW SHOWING</div>
                <div class="movie-sub-title3d">VIP Experience</div>
                <div class="title-line3d"></div>
              </div>
            </div>
          </div>
          <div class="scanlines3d"></div>
          <div class="screen-vignette3d"></div>
        </div>
      </div>

      <div id="floor3d">
        <div class="aisle-line left"></div>
        <div class="aisle-line right"></div>
      </div>

      <div id="seats3d"></div>
      <div id="ambient3d"></div>
    </div>

    <div id="particles3d"></div>
    <div id="vignette3d"></div>
    <div id="hud3d">
      <div class="hud-arrows3d"><span class="hud-arrow3d">◄</span><span class="hud-arrow3d">►</span></div>
      <div class="hud-dot3d"></div>
      <div class="hud-text3d">Move mouse to look around</div>
      <div class="hud-dot3d"></div>
    </div>
  </div>
</div>

<script src="/js/vipS.js"></script>
</body>
<button class="btn-close-3d" id="btnClose3d" onclick="toggle3dView()">✕ &nbsp;Close 3D</button>
</body>
</html>